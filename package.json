{
  "name": "auction-platform",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit",
    "worker": "tsx watch src/worker.ts",
    "db:vector-index": "tsx src/db/createVectorIndex.ts",
    "db:migrate:prod": "tsx src/db/migrate.ts",
    "test": "npm run test:integration",
    "test:integration": "vitest run src/tests/integration",
    "test:security": "vitest run src/tests/security",
    "test:contracts": "vitest run src/tests/contracts",
    "test:ai": "vitest run src/tests/ai",
    "test:workers": "vitest run src/tests/workers",
    "test:concurrency": "vitest run src/tests/concurrency",
    "test:invariants": "vitest run src/tests/invariants",
    "test:domain": "vitest run src/tests/domain-rules",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:performance": "vitest run src/tests/performance/k6-aibid2x.js",
    "test:core": "vitest run src/tests/integration src/tests/workers src/tests/domain-rules",
    "test:robustness": "vitest run src/tests/concurrency src/tests/invariants",
    "test:system": "vitest run src/tests/e2e src/tests/security src/tests/contracts",
    "test:all": "vitest run src/tests",
      "seed": "npx tsx src/db/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.0",
    "@bull-board/api": "^7.1.5",
    "@bull-board/express": "^7.1.5",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/ws": "^8.18.1",
    "@upstash/redis": "^1.38.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.77.6",
    "decimal.js": "^10.6.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.31.2",
    "express": "^4.19.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.3",
    "openai": "^6.39.0",
    "pg": "^8.11.5",
    "pino": "^9.1.0",
    "pino-http": "^10.2.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1",
    "ws": "^8.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^12.0.1",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/k6": "^2.0.0",
    "@types/node": "^20.19.41",
    "@types/pg": "^8.11.5",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^9.0.8",
    "@vitest/coverage-istanbul": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.22.4",
    "gitleaks": "^1.0.0",
    "jest": "^30.4.2",
    "k6": "^0.0.0",
    "openapi-types": "^12.1.3",
    "pino-pretty": "^11.0.0",
    "playwright": "^1.60.0",
    "supertest": "^7.2.2",
    "testcontainers": "^12.0.1",
    "ts-jest": "^29.4.11",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  },
  "description": "AI-enhanced real-time auction infrastructure. Built to signal backend complexity, AI integration, system design, and operational thinking.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
